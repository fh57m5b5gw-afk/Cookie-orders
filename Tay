<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>BakedByTay Cookies</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0b1d3a;
      color: white;
      text-align: center;
      padding: 20px;
    }

    h1 {
      color: #00bfff;
    }

    .card {
      background: #112b5c;
      padding: 20px;
      border-radius: 15px;
      margin: 20px auto;
      max-width: 300px;
      box-shadow: 0 0 15px #00bfff;
    }

    input, button {
      padding: 10px;
      margin-top: 10px;
      width: 90%;
      border-radius: 10px;
      border: none;
    }

    button {
      background: #00bfff;
      color: white;
      font-weight: bold;
      cursor: pointer;
    }

    .total {
      margin-top: 10px;
      font-size: 18px;
      color: #00ffcc;
    }
  </style>
</head>
<body>

<h1>🍪 BakedByTay Cookies</h1>
<p>$3 Each • Preorders Available • Ashley Ridge Only</p>

<div class="card">
  <h2>Red Velvet Oreo</h2>
  <p>$3</p>
  <input type="number" id="qty1" placeholder="Quantity" min="0" oninput="calcTotal()">
</div>

<div class="card">
  <h2>Cookies & Cream</h2>
  <p>$3</p>
  <input type="number" id="qty2" placeholder="Quantity" min="0" oninput="calcTotal()">
</div>

<div class="total">
  Total: $<span id="total">0</span>
</div>

<button onclick="submitOrder()">Place Order</button>

<script>
function calcTotal() {
  let q1 = document.getElementById("qty1").value || 0;
  let q2 = document.getElementById("qty2").value || 0;

  let total = (q1 * 3) + (q2 * 3);
  document.getElementById("total").innerText = total;
}

function submitOrder() {
  alert("Order sent! (You can connect this to Formspree later)");
}
</script>

</body>
</html>
